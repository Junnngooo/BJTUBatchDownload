{
  "manifest_version": 3,
  "name": "MIS课件批量下载器",
  "version": "2.1.0",
  "description": "批量下载BJTU MIS课程平台课件，自动按课程分类，防止Cookie过期",
  "permissions": [
    "downloads",
    "scripting",
    "storage",
    "tabs",
    "cookies",
    "alarms"
  ],
  "host_permissions": [
    "https://mis.bjtu.edu.cn/*",
    "http://123.121.147.7:88/*"
  ],
  "action": {
    "default_title": "MIS课件下载器",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mis.bjtu.edu.cn/*",
        "http://123.121.147.7:88/*"
      ],
      "js": ["src/content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/page/page.html", "src/page/page.css", "src/page/page.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self'; img-src 'self' data:;"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
